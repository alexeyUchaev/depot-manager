# --- Database (Supabase) ---
# App runtime + seed: use the TRANSACTION pooler (port 6543). It multiplexes
# connections so serverless functions don't exhaust Supabase's client limit.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations & db push: use the SESSION pooler (port 5432) or the direct
# connection. `prisma migrate` / `db push` need a real session, not the
# transaction pooler. Read by prisma.config.ts.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Optional: cap each app instance's connection pool (default 3).
# DATABASE_POOL_MAX=3
#
# For a local Postgres instead, point both at it:
# DATABASE_URL=postgresql://user:password@localhost:5432/depot
# DIRECT_URL=postgresql://user:password@localhost:5432/depot

# Google Gemini API key — powers the AI assistant (app/api/chat)
GEMINI_API_KEY=

# Optional: extra cross-origin dev host for `next dev` (e.g. an ngrok tunnel)
# NEXT_PUBLIC_DEV_ORIGIN=your-tunnel.ngrok-free.dev

# App base URL used to build Stripe success/cancel redirect targets
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe ---
# Use TEST keys (sk_test_..., pk_test_...) for development. Switching to live
# mode is just swapping these values — no code changes needed. See STRIPE_TESTING.md.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Signing secret for the webhook endpoint (from `stripe listen` or the dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price id for the PRO subscription plan
STRIPE_PRICE_PRO=price_...
