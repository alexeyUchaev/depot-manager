# PostgreSQL connection string (used by Prisma and the seed script)
DATABASE_URL=postgresql://user:password@localhost:5432/depot

# Google Gemini API key — powers the AI assistant (app/api/chat)
GEMINI_API_KEY=

# Optional: extra cross-origin dev host for `next dev` (e.g. an ngrok tunnel)
# NEXT_PUBLIC_DEV_ORIGIN=your-tunnel.ngrok-free.dev

# App base URL used to build Stripe success/cancel redirect targets
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe ---
# Use TEST keys (sk_test_..., pk_test_...) for development. Switching to live
# mode is just swapping these values — no code changes needed. See STRIPE_TESTING.md.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Signing secret for the webhook endpoint (from `stripe listen` or the dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price id for the PRO subscription plan
STRIPE_PRICE_PRO=price_...
