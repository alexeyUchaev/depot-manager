generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  clerkOrgId           String    @unique
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // active / past_due / canceled / incomplete ...
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())

  users     User[]
  products  Product[]
  orders    Order[]
  intakes   Intake[]
  movements StockMovement[]
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  tenantId    String?
  email       String   @unique
  firstName   String?
  lastName    String?
  department  String?
  role        UserRole @default(staff)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  Intakes   Intake[] 
  org       Tenant?         @relation(fields: [tenantId], references: [id])
  orders    Order[]
  movements StockMovement[]
}

model Product {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  sku        String
  category   String?
  location   String?
  cachedQuantity Int   @default(0)
  price      Decimal  @db.Decimal(10, 2)
  lowStockAt Int      @default(10)
  createdAt  DateTime @default(now())

  org        Tenant    @relation(fields: [orgId], references: [id])
  intakes    IntakeItem[]
  movements  StockMovement[]
  orderItems OrderItem[]

  @@unique([orgId, sku])
}

model StockMovement {
  id        String       @id @default(cuid())
  orgId     String
  productId String
  userId    String
  orderId   String?
  takeId    String?
  type      MovementType  
  
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  org     Tenant @relation(fields: [orgId], references: [id])
  product Product      @relation(fields: [productId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  order   Order?       @relation(fields: [orderId], references: [id])
  intake  Intake?      @relation(fields: [takeId], references: [id])
}

model Order {
  id           String      @id @default(cuid())
  orgId        String
  userId       String
  orderNumber  String
  customerName String
  status       OrderStatus @default(AWAITING_PAYMENT)
  createdAt    DateTime    @default(now())

  // Stripe payment tracking. Stock (OUT movements) is only dispatched once the
  // order is actually paid (handled in the Stripe webhook), so an unpaid order
  // never silently consumes inventory.
  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId   String?   @unique
  paidAt                  DateTime?
  amountTotal             Int? // amount charged, in the smallest currency unit (cents)
  currency                String?   @default("usd")

  org       Tenant @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  items     OrderItem[]
  movements StockMovement[]

  @@unique([orgId, orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Intake {
  id           String      @id @default(cuid())
  orgId        String
  userId       String
  intakeNumber  String
  customerName String
  status       IntakeStatus @default(REQUESTED)
  createdAt    DateTime    @default(now())

  org       Tenant @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  items     IntakeItem[]
  movements StockMovement[]

  @@unique([orgId, intakeNumber])
}

model IntakeItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Intake   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum UserRole {
  owner
  manager
  staff
}

enum Plan {
  FREE
  PRO
}

enum MovementType {
  IN
  OUT
}

enum OrderStatus {
  AWAITING_PAYMENT
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum IntakeStatus {
  REQUESTED
  IN_TRANSIT
  ARRIVED
  ACCEPTED
  REJECTED
}

// Stripe delivers webhook events at-least-once, so the handler must be
// idempotent. We record every processed event id here and skip duplicates.
model ProcessedStripeEvent {
  id          String   @id // Stripe event.id
  type        String
  processedAt DateTime @default(now())
}